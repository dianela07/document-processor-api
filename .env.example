# ===================================
# Document Processor API - Configuration
# ===================================
# Copy this file to .env and fill in your values

# ===================================
# Application Settings
# ===================================
APP_NAME=Document Processor API
APP_VERSION=1.0.0
DEBUG=false

# ===================================
# Server Configuration
# ===================================
HOST=0.0.0.0
PORT=8000

# ===================================
# Database
# ===================================
# SQLite database path (relative to backend/src/)
DATABASE_URL=sqlite:///data/document_processor.db

# ===================================
# LLM Provider Selection
# ===================================
# Options: "groq" | "ollama" | "azure" | "none"
# - groq: Free cloud API (recommended for getting started)
# - ollama: Local LLM (100% free, requires Ollama installed)
# - azure: Azure OpenAI (paid)
# - none: Disable LLM extraction
LLM_PROVIDER=groq

# ===================================
# Groq Configuration (Free tier available)
# ===================================
# Get your API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ===================================
# Ollama Configuration (Local)
# ===================================
# Install Ollama: https://ollama.ai/
# Then run: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ===================================
# Azure OpenAI Configuration (Paid)
# ===================================
# AZURE_OPENAI_KEY=your_azure_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_MODEL=gpt-4o-mini

# ===================================
# Processing Limits
# ===================================
MAX_FILE_SIZE_MB=10
MAX_TEXT_LENGTH_FOR_LLM=4000
MAX_REPORT_RECORDS=1000

# ===================================
# LLM Parameters
# ===================================
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.1

# ===================================
# Logging
# ===================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
